{
  "schemaVersion": 3,
  "stageModules": {},
  "starterFragments": {
    "next-web-foundation": {
      "presetIds": [
        "next-web"
      ],
      "post_setup": {
        "docker_compose": false,
        "verification_profile": "web",
        "design_platform": "web",
        "selected_profiles": [
          "workspace-kernel",
          "docs-sync",
          "deterministic-verification",
          "web-platform"
        ]
      }
    },
    "expo-mobile-foundation": {
      "presetIds": [
        "expo-mobile"
      ],
      "post_setup": {
        "docker_compose": false,
        "verification_profile": "mobile",
        "design_platform": "expo",
        "selected_profiles": [
          "workspace-kernel",
          "docs-sync",
          "deterministic-verification",
          "mobile-platform"
        ]
      }
    },
    "backend-service-foundation": {
      "presetIds": [
        "nestjs-api",
        "rust-service"
      ],
      "post_setup": {
        "docker_compose": true,
        "verification_profile": "backend",
        "selected_profiles": [
          "workspace-kernel",
          "docs-sync",
          "deterministic-verification",
          "backend-platform",
          "local-infra"
        ]
      }
    },
    "nx-fullstack-foundation": {
      "presetIds": [
        "nx-fullstack"
      ],
      "post_setup": {
        "docker_compose": true,
        "verification_profile": "monorepo",
        "design_platform": "web",
        "selected_profiles": [
          "workspace-kernel",
          "docs-sync",
